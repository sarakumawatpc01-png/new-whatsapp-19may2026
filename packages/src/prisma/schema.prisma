datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TENANT_OWNER
  AGENT
  BOT
}

enum OptStatus {
  OPTED_IN
  OPTED_OUT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  CANCELLED
}

enum WhatsAppNumberStatus {
  ACTIVE
  DISCONNECTED
  FLAGGED
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum AutomationTrigger {
  MESSAGE_RECEIVED
  KEYWORD_MATCH
  TAG_ADDED
  TAG_REMOVED
  CONTACT_CREATED
  INACTIVITY
  SCHEDULED
  CONVERSATION_ASSIGNED
  CONVERSATION_RESOLVED
  BUTTON_CLICKED
  FLOW_SUBMITTED
}

enum AutomationNodeStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  OPTED_OUT
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum WebhookEventType {
  MESSAGE_RECEIVED
  MESSAGE_SENT
  MESSAGE_DELIVERED
  MESSAGE_READ
  MESSAGE_FAILED
  CONTACT_CREATED
  TAG_ADDED
  TAG_REMOVED
  CAMPAIGN_SENT
  CAMPAIGN_DELIVERED
  CAMPAIGN_READ
  CAMPAIGN_OPT_OUT
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum AIProvider {
  OPENROUTER
  OPENAI
  ANTHROPIC
  GOOGLE
  GROQ
  DEEPSEEK
  QWEN
  OLLAMA
}

enum PlanType {
  FREE
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("TRIALING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  subscriptions    Subscription[]
  featureFlags     FeatureFlag[]
  onboardingSteps  OnboardingStep[]
  whatsAppNumbers  WhatsAppNumber[]
  conversations    Conversation[]
  contacts         Contact[]
  campaigns        Campaign[]
  templates        Template[]
  automations      Automation[]
  pages            Page[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  notifications    Notification[]
  aiConfigs        AIConfig[]
  analyticsEvents  AnalyticsEvent[]
  dailyMetrics     DailyMetric[]
  aiUsageLogs      AIUsageLog[]
  aiMemories       AIMemory[]
  invoices         Invoice[]
  coupons          Coupon[]
  resellerId       String?
  reseller         Reseller?         @relation(fields: [resellerId], references: [id])
  Message          Message[]
  Tag              Tag[]
  CustomField      CustomField[]
  AutomationRun    AutomationRun[]
  WebhookEvent     WebhookEvent[]
  Deal             Deal[]

  @@index([slug])
}

model Reseller {
  id            String   @id @default(cuid())
  name          String
  domain        String?  @unique
  logoUrl       String?
  primaryColor  String   @default("#3b82f6")
  accentColor   String   @default("#8b5cf6")
  theme         String   @default("dark")
  hidePoweredBy Boolean  @default(false)
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenants Tenant[]
  plans   Plan[]

  @@index([domain])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatarUrl     String?
  role          Role     @default(TENANT_OWNER)
  passwordHash  String
  isActive      Boolean  @default(true)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  sessions               Session[]
  conversations          Conversation[]
  assignedConversations  Conversation[]           @relation("Assignee")
  notes                  ConversationNote[]
  notifications          Notification[]
  VerificationToken      VerificationToken[]
  PasswordReset          PasswordReset[]
  ContactNote            ContactNote[]
  NotificationPreference NotificationPreference[]

  @@index([email])
  @@index([tenantId])
}

model Session {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Subscription {
  id                 String             @id @default(cuid())
  status             SubscriptionStatus @default(TRIALING)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  invoices Invoice[]

  @@index([tenantId])
  @@index([planId])
}

model Plan {
  id             String   @id @default(cuid())
  name           String
  type           PlanType @default(FREE)
  price          Float    @default(0)
  currency       String   @default("USD")
  interval       String   @default("month")
  isPublic       Boolean  @default(true)
  maxMessages    Int      @default(1000)
  maxContacts    Int      @default(1000)
  maxCampaigns   Int      @default(10)
  maxAiTokens    Int      @default(50000)
  maxStorage     Int      @default(100)
  features       Json
  stripePriceId  String?
  razorpayPlanId String?
  paypalPlanId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resellerId String?
  reseller   Reseller? @relation(fields: [resellerId], references: [id])

  subscriptions Subscription[]
  coupons       Coupon[]

  @@index([type])
  @@index([resellerId])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String // "percentage" | "fixed"
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  invoices Invoice[]
  Tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId String?

  @@index([code])
  @@index([planId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  amount        Float
  currency      String        @default("USD")
  status        InvoiceStatus @default(OPEN)
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([couponId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WhatsAppNumber {
  id            String               @id @default(cuid())
  phoneNumberId String
  displayName   String?
  status        WhatsAppNumberStatus @default(DISCONNECTED)
  qualityRating String               @default("UNKNOWN")
  messagingTier Int                  @default(1)
  accessToken   String?
  wabaId        String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  conversations Conversation[]
  AIConfig      AIConfig[]
  Campaign      Campaign[]

  @@index([tenantId])
  @@index([phoneNumberId])
}

model Conversation {
  id             String    @id @default(cuid())
  status         String    @default("OPEN") // OPEN, RESOLVED, SNOOZED
  assignedToId   String?
  lastMessageAt  DateTime?
  windowOpenAt   DateTime?
  windowClosesAt DateTime?
  snoozedUntil   DateTime?
  aiPaused       Boolean   @default(false)
  humanTookOver  Boolean   @default(false)
  summary        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  whatsAppNumberId String?
  whatsAppNumber   WhatsAppNumber? @relation(fields: [whatsAppNumberId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  assignedTo User? @relation("Assignee", fields: [assignedToId], references: [id])

  messages       Message[]
  notes          ConversationNote[]
  automationRuns AutomationRun[]
  User           User?              @relation(fields: [userId], references: [id])
  userId         String?

  @@index([tenantId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([whatsAppNumberId])
  @@index([status])
}

model Message {
  id            String   @id @default(cuid())
  direction     String // "INBOUND" | "OUTBOUND"
  type          String // "TEXT" | "IMAGE" | "VIDEO" | "AUDIO" | "DOCUMENT" | "LOCATION" | "STICKER" | "INTERACTIVE" | "TEMPLATE"
  content       String?
  mediaUrl      String?
  mediaType     String?
  mediaId       String?
  caption       String?
  status        String   @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  isAiGenerated Boolean  @default(false)
  metaMessageId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([contactId])
  @@index([status])
}

model Contact {
  id         String    @id @default(cuid())
  name       String?
  phone      String
  email      String?
  company    String?
  avatarUrl  String?
  optStatus  OptStatus @default(OPTED_IN)
  isBlocked  Boolean   @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  customFieldValues ContactCustomFieldValue[]
  conversations     Conversation[]
  messages          Message[]
  tags              ContactTag[]
  deals             Deal[]
  notes             ContactNote[]
  AutomationRun     AutomationRun[]
  CampaignRecipient CampaignRecipient[]
  AIMemory          AIMemory[]

  @@index([tenantId])
  @@index([phone])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  contacts ContactTag[]

  @@index([tenantId])
  @@index([name])
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

model CustomField {
  id         String   @id @default(cuid())
  key        String
  label      String
  fieldType  String // "TEXT" | "NUMBER" | "DATE" | "BOOLEAN" | "SELECT"
  options    Json?
  isRequired Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  contactValues ContactCustomFieldValue[]

  @@index([tenantId])
  @@index([key])
}

model ContactCustomFieldValue {
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  value         String

  @@id([contactId, customFieldId])
  @@index([contactId])
  @@index([customFieldId])
}

model ConversationNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([userId])
}

model ContactNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([userId])
}

model AIConfig {
  id                  String     @id @default(cuid())
  provider            AIProvider @default(OPENROUTER)
  model               String
  systemPrompt        String
  autoReplyEnabled    Boolean    @default(false)
  autoReplyDelay      Int        @default(0)
  confidenceThreshold Float      @default(0.7)
  shortTermLimit      Int        @default(10)
  summarizeAfter      Int        @default(50)
  isActive            Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  whatsAppNumberId String?
  whatsAppNumber   WhatsAppNumber? @relation(fields: [whatsAppNumberId], references: [id])

  @@index([tenantId])
  @@index([whatsAppNumberId])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  feature   String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([feature])
}

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  trigger       AutomationTrigger
  triggerConfig Json?
  nodes         Json
  edges         Json

  runs AutomationRun[]

  @@index([tenantId])
  @@index([isActive])
}

model AutomationRun {
  id          String    @id @default(cuid())
  status      String    @default("RUNNING") // RUNNING, COMPLETED, FAILED
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  nodeResults Json?
  error       String?

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  @@index([automationId])
  @@index([tenantId])
  @@index([conversationId])
  @@index([contactId])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  templateId String
  template   Template @relation(fields: [templateId], references: [id])

  whatsAppNumberId String?
  whatsAppNumber   WhatsAppNumber? @relation(fields: [whatsAppNumberId], references: [id])

  recipients CampaignRecipient[]

  @@index([tenantId])
  @@index([templateId])
  @@index([whatsAppNumberId])
  @@index([status])
}

model CampaignRecipient {
  id           String                  @id @default(cuid())
  status       CampaignRecipientStatus @default(PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedReason String?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([contactId])
  @@index([status])
}

model Template {
  id             String           @id @default(cuid())
  name           String
  category       TemplateCategory
  language       String           @default("en")
  status         TemplateStatus   @default(DRAFT)
  metaTemplateId String?
  components     Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  campaigns Campaign[]

  @@index([tenantId])
  @@index([status])
}

model Page {
  id          String     @id @default(cuid())
  slug        String
  title       String
  content     String
  css         String?
  isHomepage  Boolean    @default(false)
  status      PageStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@index([slug])
  @@index([tenantId])
  @@index([isHomepage])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyPrefix   String
  keyHash     String
  permissions Json
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([keyPrefix])
}

model WebhookEndpoint {
  id             String    @id @default(cuid())
  url            String
  events         Json
  isActive       Boolean   @default(true)
  lastDeliveryAt DateTime?
  failureCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookEvent {
  id        String           @id @default(cuid())
  eventType WebhookEventType
  source    String
  payload   Json
  processed Boolean          @default(false)
  createdAt DateTime         @default(now())

  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  WebhookDelivery WebhookDelivery[]

  @@index([tenantId])
  @@index([eventType])
  @@index([processed])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  eventId       String
  endpointId    String
  status        String // "PENDING" | "SENT" | "FAILED"
  responseCode  Int?
  responseBody  String?
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime  @default(now())

  webhookEvent WebhookEvent    @relation(fields: [eventId], references: [id])
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([eventId])
  @@index([endpointId])
  @@index([status])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  eventData Json
  createdAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
}

model DailyMetric {
  id         String   @id @default(cuid())
  date       DateTime @unique
  metricType String
  value      Float
  tenantId   String?
  Tenant     Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([date])
  @@index([metricType])
  @@index([tenantId])
}

model AIUsageLog {
  id               String     @id @default(cuid())
  provider         AIProvider
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float
  latency          Int
  createdAt        DateTime   @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

model AIMemory {
  id            String   @id @default(cuid())
  contactId     String
  contact       Contact  @relation(fields: [contactId], references: [id])
  summary       String
  lastUpdatedAt DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([contactId])
  @@index([tenantId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  actionUrl String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([isRead])
}

model NotificationPreference {
  type    String
  channel NotificationChannel
  enabled Boolean             @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, type, channel])
}

model OnboardingStep {
  id          String    @id @default(cuid())
  step        String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Deal {
  id                String    @id @default(cuid())
  title             String
  value             Float
  currency          String    @default("USD")
  stage             String
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([contactId])
  @@index([tenantId])
}
