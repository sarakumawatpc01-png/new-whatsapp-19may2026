# ══════════════════════════════════════════════
# AI-NATIVE WHATSAPP SAAS PLATFORM
# Environment Configuration Template
# ══════════════════════════════════════════════

# ── Core ──────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/db?sslmode=require
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-characters
JWT_PUBLIC_KEY=your-jwt-public-key
JWT_PRIVATE_KEY=your-jwt-private-key
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-characters
NEXTAUTH_URL=http://localhost:3000
ENCRYPTION_KEY=your-encryption-key-for-aes-256

# ── Meta / WhatsApp ───────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-custom-webhook-verify-token
META_SYSTEM_USER_TOKEN=your-system-user-token
META_CONFIG_ID=your-embedded-signup-config-id
META_API_VERSION=v19.0
META_REGISTRATION_PIN=
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
NEXT_PUBLIC_META_CONFIG_ID=your-config-id

# ── AI Providers (at least one required) ──────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Object Storage (MinIO/S3) ────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=whatsapp-saas
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Email ────────────────────────────────────
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Payments ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Frontend ─────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Monitoring ───────────────────────────────
SENTRY_DSN=
