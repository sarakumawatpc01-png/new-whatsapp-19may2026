# Database & Redis
DATABASE_URL="postgresql://user:password@localhost:5432/db?sslmode=require"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your_jwt_secret_32_chars_minimum"
JWT_REFRESH_SECRET="your_refresh_secret_32_chars_minimum"
JWT_PUBLIC_KEY="your_public_key"
JWT_PRIVATE_KEY="your_private_key"
NEXTAUTH_SECRET="your_nextauth_secret_32_chars_minimum"
NEXTAUTH_URL="http://localhost:3000"

# Infrastructure
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="whatsapp-saas"
S3_ACCESS_KEY="your_access_key"
S3_SECRET_KEY="your_secret_key"
S3_REGION="us-east-1"

# Meta / WhatsApp
META_APP_ID="your_app_id"
META_APP_SECRET="your_app_secret"
META_VERIFY_TOKEN="your_verify_token"

# API & Frontend URLs
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# AI & Other Keys
OPENAI_API_KEY="sk-your-key"
OPENROUTER_API_KEY="your-key"
RESEND_API_KEY="your-key"
ENCRYPTION_KEY="your_encryption_key_32_chars"
STRIPE_SECRET_KEY="sk_test_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_secret"
RAZORPAY_KEY_ID="rzp_test_your_id"
RAZORPAY_KEY_SECRET="your_secret"

# System
NODE_ENV="development"
PORT=3001
